<style>
  .btn-search{
    background-color: #fe424d;
    color: aliceblue;
    border-radius:1.5rem;
    padding: 0 1rem 0 1rem;
  }
  .btn-search i{
    display: inline;
    margin-right: 0.5rem;
  }
  .search-sp{
     border-radius:1.5rem;
     width:300px;
  }
  .explore{
    border: 0.5px solid rgb(74, 122, 217);
    border-radius:1rem;
    width: 100px;
    height: 2.5rem;
    text-align: center;
    padding-left: 0.7rem;  }
</style>
<nav class="navbar navbar-expand-md bg-light shadow-sm sticky-top">
  <div class="container-fluid">

    <!-- Logo + Brand -->
    <a class="navbar-brand d-flex align-items-center" href="/listings">
      <img src="/images/logo.png" alt="Wonderlust Logo" height="45" class="me-2">
      <span class="fw-bold text-danger">Wonderlust</span>
    </a>

    <!-- Mobile Toggle Button -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar Links -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup" style="margin-left: 2rem;">
      <div class="navbar-nav explore">
        <a class="nav-link " href="/listings">Explore</a>
      </div>
      <div class="navbar-nav ms-auto">
        <form class="d-flex" role="search">
        <input class="form-control me-2 search-sp" type="search" placeholder="Search   destination" aria-label="Search"/>
        <button class="btn btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
      </form>
      </div>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">wonderlust your home</a>
        <% if(!currUser){%>
          <a class="nav-link" href="/signup"><b>signup</b></a>
          <a class="nav-link" href="/login"><b>login</b></a>
        <% } %>
        <% if(currUser){%>
        <a class="nav-link" href="/logout"><b>logout</b></a>
        <%}%>
      </div>
    </div>

  </div>
</nav>