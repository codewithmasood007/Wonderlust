<% layout('layouts/boilerplate') %>
<div class="row mt-3">
  <div class="col-6 offset-3">
    <h1 class=" offset-2 text-danger">SignUp on Wonderlust</h2>
    <form action="/signup" method="post" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-level">username</label>
        <input
          type="text"
          name="username"
          id="username"
          class="form-control"
          required
        />
        <div class="valid-feedback">looks good!</div>
      </div>
      <div class="mb-3">
        <label for="email" class="form-level">email</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control"
          required
        />
        <div class="valid-feedback">looks good!</div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-level">password</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control"
          required
        />
        <div class="valid-feedback">looks good!</div>
      </div>
      <div>
        <button class="btn btn-success">Signup</button>
      </div>
    </form>
  </div>
</div>
